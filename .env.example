# GroupFlow 环境变量示例
# 复制为 .env 后即可用于 docker compose up。
# 默认值面向 Docker Compose（主机名为各服务的 compose 服务名）。
# 若在本机直接 go run（依赖跑在容器里），请把下方 mysql/redis/kafka/elasticsearch
# 主机名改成 localhost。

# ---- 基础 ----
APP_ENV=prod
HTTP_ADDR=:8080
SERVER_ID=ws-server-01
PUBLIC_BASE_URL=http://localhost

# ---- MySQL ----
MYSQL_DSN=groupflow:groupflow@tcp(mysql:3306)/groupflow?parseTime=true&loc=Local&charset=utf8mb4

# ---- Redis ----
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Kafka（Outbox + 异步投递链路）----
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_MESSAGE_TOPIC=group-message-topic
KAFKA_CONSUMER_GROUP=groupflow-delivery

# ---- 鉴权 ----
AUTH_SECRET=groupflow-dev-secret
TOKEN_TTL_HOURS=168

# ---- WebSocket 多节点路由 ----
WS_INTERNAL_PUSH_URL=http://groupflow-api:8080/internal/push
WS_ADVERTISE_PUSH_URL=http://groupflow-api:8080/internal/push

# ---- group_message 分表（>1 时按 group_id 哈希路由到 group_message_NN）----
MESSAGE_SHARD_COUNT=1

# ---- Elasticsearch 聊天历史搜索 ----
ES_ENABLED=true
ES_ADDRS=http://elasticsearch:9200
ES_INDEX=group_message
ES_INDEXER_CONSUMER_GROUP=groupflow-es-indexer

# ---- 日志 ----
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
